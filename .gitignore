# Environment variables — never commit real secrets
.env
.env.local
.env.*.local

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log
npm-debug.log*

# Node (if ever added)
node_modules/

# Python (if ever added)
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Uploads (user-generated content, not source)
uploads/*
!uploads/.gitkeep
